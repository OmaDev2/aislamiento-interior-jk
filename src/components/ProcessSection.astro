---
---

<section id="proceso" class="py-24 lg:py-32 bg-gray-50 overflow-hidden">
  <div class="container mx-auto px-4">
    <!-- Header -->
    <div class="max-w-4xl mx-auto text-center mb-16 lg:mb-24">
      <span class="inline-block px-4 py-1.5 bg-blue-100 text-blue-700 text-xs font-black uppercase tracking-widest rounded-full mb-6 italic">PROCESO CERTIFICADO</span>
      <h2 class="text-3xl md:text-5xl font-black text-gray-900 leading-tight mb-8">
        Cómo Instalamos Beissier Therm In <br class="hidden md:block" /> 
        <span class="text-blue-700">En Tu Vivienda de Barcelona</span>
      </h2>
      <p class="text-xl text-gray-500 font-medium italic">En solo 2-3 días, sin obras molestas y con limpieza total.</p>
      <div class="h-1.5 w-24 bg-[#F97316] mx-auto rounded-full mt-8"></div>
    </div>

    <!-- Timeline Grid -->
    <div class="max-w-5xl mx-auto relative">
      <!-- Vertical Line (Desktop) -->
      <div class="hidden lg:block absolute left-1/2 top-0 bottom-0 w-1 bg-blue-100 -translate-x-1/2 z-0"></div>

      <div class="space-y-16 lg:space-y-24 relative z-10">
        {[
          {
            num: "1",
            title: "Desmontaje y Preparación",
            items: [
              "Carpinteros desmontan radiadores y zócalos",
              "Electricistas retiran mecanismos y enchufes",
              "Protección total de suelos y mobiliario",
              "Aspiración integrada: trabajo <strong>sin polvo</strong>"
            ],
            time: "Día 1: Preparación",
            side: "left"
          },
          {
            num: "2",
            title: "Instalación del Sistema",
            items: [
              "Colocación de placas Beissier Therm In",
              "Aplicación de malla de refuerzo (160g/m²)",
              "Sellado técnico de juntas y perímetros",
              "Control exhaustivo de puentes térmicos"
            ],
            time: "Día 1-2: Aislamiento",
            side: "right"
          },
          {
            num: "3",
            title: "Tendido y Alisado Profesional",
            items: [
              "Aplicación de revoco multicapa",
              "Alisado maestro de alta calidad",
              "Paredes perfectamente niveladas",
              "Listo para pintar (acabado premium)"
            ],
            time: "Día 2: Acabado",
            side: "left"
          },
          {
            num: "4",
            title: "Montaje Final y Entrega",
            items: [
              "Reinstalación de radiadores y electricidad",
              "Montaje de carpintería y acabados",
              "Limpieza profunda final",
              "Doble garantía: Materiales + Ejecución"
            ],
            time: "Día 3: Entrega",
            side: "right"
          }
        ].map((step) => (
          <div class={`flex flex-col lg:flex-row items-center gap-8 lg:gap-0 ${step.side === 'right' ? 'lg:flex-row-reverse' : ''}`}>
            <!-- Content -->
            <div class={`lg:w-[45%] w-full ${step.side === 'left' ? 'text-right' : 'text-left'}`}>
              <div class={`bg-white p-8 rounded-[2rem] shadow-xl border border-gray-100 hover:border-blue-200 transition-all duration-300 relative group`}>
                <div class={`absolute top-6 ${step.side === 'left' ? '-right-3' : '-left-3'} hidden lg:block`}>
                   <div class="w-6 h-6 bg-white border-t border-l border-gray-100 rotate-45 group-hover:border-blue-200 transition-colors"></div>
                </div>
                
                <span class="text-[#F97316] font-black text-xs uppercase tracking-widest mb-4 block italic">{step.time}</span>
                <h3 class="text-2xl font-black text-gray-900 mb-6 leading-tight group-hover:text-blue-900 transition-colors">{step.title}</h3>
                
                <ul class={`space-y-3 ${step.side === 'left' ? 'flex flex-col items-end' : ''}`}>
                  {step.items.map((item) => (
                    <li class="flex items-start gap-3">
                      {step.side === 'right' && <div class="w-1.5 h-1.5 bg-[#F97316] rounded-full mt-2 shrink-0"></div>}
                      <span class="text-gray-500 text-sm font-medium leading-relaxed" set:html={item}></span>
                      {step.side === 'left' && <div class="w-1.5 h-1.5 bg-[#F97316] rounded-full mt-2 shrink-0"></div>}
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <!-- Number (Center) -->
            <div class="lg:w-[10%] flex justify-center items-center relative">
              <div class="w-16 h-16 bg-blue-900 rounded-full border-4 border-white shadow-xl flex items-center justify-center text-white text-2xl font-black z-20 transition-transform hover:scale-110">
                {step.num}
              </div>
            </div>

            <!-- Spacer -->
            <div class="lg:w-[45%] hidden lg:block"></div>
          </div>
        ))}
      </div>
    </div>

    <!-- Final Trust Signal -->
    <div class="mt-24 max-w-4xl mx-auto bg-[#1E3A8A] rounded-[3rem] p-12 text-center text-white shadow-2xl shadow-blue-900/30 overflow-hidden relative">
       <div class="absolute top-0 right-0 p-8 opacity-10">
         <svg class="w-32 h-32" fill="currentColor" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
       </div>
       <h4 class="text-2xl md:text-3xl font-black mb-6">¿Quieres un presupuesto sin compromiso?</h4>
       <p class="text-lg text-white/80 mb-10 max-w-2xl mx-auto">Visita técnica gratuita en toda Barcelona para evaluar puentes térmicos y condensación.</p>
       <div class="flex flex-col sm:flex-row gap-6 justify-center">
         <a href="#contacto" class="bg-[#F97316] hover:bg-white hover:text-blue-900 text-white px-8 py-5 rounded-full font-black text-lg transition-all shadow-xl shadow-black/20">ME INTERESA UN DIAGNÓSTICO</a>
         <a href="tel:935555555" class="bg-white/10 hover:bg-white/20 backdrop-blur-md px-8 py-5 rounded-full font-black text-lg transition-all border border-white/20">LLAMAR AHORA: 93 555 55 55</a>
       </div>
    </div>
  </div>
</section>
