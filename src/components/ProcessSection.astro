---
import business from '../data/business.json'
import home from '../data/home.json'

const { badge, heading, headingHighlight, subtitle, steps, trustSignal } = home.process
---

<section id="proceso" class="py-24 lg:py-32 bg-white overflow-hidden">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto text-center mb-16 lg:mb-24">
      <span class="inline-block px-4 py-1.5 bg-blue-100 text-blue-700 text-xs font-black uppercase tracking-widest rounded-full mb-6">{badge}</span>
      <h2 class="text-3xl md:text-5xl font-black text-gray-900 leading-tight mb-8">
        {heading} <br class="hidden md:block" />
        <span class="text-blue-700">{headingHighlight}</span>
      </h2>
      <p class="text-xl text-gray-500 font-medium">{subtitle}</p>
      <div class="h-1.5 w-24 bg-brand-orange mx-auto rounded-full mt-8"></div>
    </div>

    <div class="max-w-5xl mx-auto relative">
      <div class="hidden lg:block absolute left-1/2 top-0 bottom-0 w-1 bg-blue-100 -translate-x-1/2 z-0"></div>

      <div class="space-y-16 lg:space-y-24 relative z-10">
        {steps.map((step, i) => {
          const side = i % 2 === 0 ? 'left' : 'right'
          const num = String(i + 1)
          return (
            <div class={`flex flex-col lg:flex-row items-center gap-8 lg:gap-0 ${side === 'right' ? 'lg:flex-row-reverse' : ''}`}>
              <div class={`lg:w-[45%] w-full ${side === 'left' ? 'text-right' : 'text-left'}`}>
                <div class="bg-white p-8 rounded-3xl shadow-xl border border-gray-100 hover:border-blue-200 transition-all duration-300 relative group">
                  <div class={`absolute top-6 ${side === 'left' ? '-right-3' : '-left-3'} hidden lg:block`}>
                     <div class="w-6 h-6 bg-white border-t border-l border-gray-100 rotate-45 group-hover:border-blue-200 transition-colors"></div>
                  </div>

                  <span class="text-brand-orange font-black text-xs uppercase tracking-widest mb-4 block">{step.time}</span>
                  <h3 class="text-2xl font-black text-gray-900 mb-6 leading-tight group-hover:text-blue-900 transition-colors">{step.title}</h3>

                  <ul class={`space-y-3 ${side === 'left' ? 'flex flex-col items-end' : ''}`}>
                    {step.items.map((item) => (
                      <li class="flex items-start gap-3">
                        {side === 'right' && <div class="w-1.5 h-1.5 bg-brand-orange rounded-full mt-2 shrink-0"></div>}
                        <span class="text-gray-500 text-sm font-medium leading-relaxed" set:html={item}></span>
                        {side === 'left' && <div class="w-1.5 h-1.5 bg-brand-orange rounded-full mt-2 shrink-0"></div>}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>

              <div class="lg:w-[10%] flex justify-center items-center relative">
                <div class="w-16 h-16 bg-blue-900 rounded-full border-4 border-white shadow-xl flex items-center justify-center text-white text-2xl font-black z-20 transition-transform hover:scale-110">
                  {num}
                </div>
              </div>

              <div class="lg:w-[45%] hidden lg:block"></div>
            </div>
          )
        })}
      </div>
    </div>

    <div class="mt-24 max-w-4xl mx-auto bg-brand-blue rounded-3xl p-12 text-center text-white shadow-2xl shadow-blue-900/30 overflow-hidden relative">
       <div class="absolute top-0 right-0 p-8 opacity-10">
         <svg class="w-32 h-32" fill="currentColor" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
       </div>
       <h4 class="text-2xl md:text-3xl font-black mb-6">{trustSignal.heading}</h4>
       <p class="text-lg text-white/80 mb-10 max-w-2xl mx-auto">{trustSignal.text}</p>
       <div class="flex flex-col sm:flex-row gap-6 justify-center">
         <a href="#contacto" class="bg-brand-orange hover:bg-white hover:text-blue-900 text-white px-8 py-5 rounded-full font-black text-lg transition-all shadow-xl shadow-black/20">{trustSignal.ctaPrimary}</a>
         <a href={`tel:${business.phone}`} class="bg-white/10 hover:bg-white/20 backdrop-blur-md px-8 py-5 rounded-full font-black text-lg transition-all border border-white/20">{trustSignal.ctaSecondary} {business.phone}</a>
       </div>
    </div>
  </div>
</section>
