---
import business from '../data/business.json'
import home from '../data/home.json'

const { badge, heading, headingHighlight, items: faqs, supportText, whatsappCta } = home.faq
const whatsappUrl = `https://wa.me/${business.phone.replace(/[\s\-\+]/g, '')}`
---

<section id="faq" class="py-24 lg:py-32 bg-white overflow-hidden">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto text-center mb-16 lg:mb-24">
      <span class="inline-block px-4 py-1.5 bg-blue-100 text-blue-700 text-xs font-black uppercase tracking-widest rounded-full mb-6">{badge}</span>
      <h2 class="text-3xl md:text-5xl font-black text-gray-900 leading-tight mb-8">
        {heading} <br class="hidden md:block" />
        <span class="text-blue-700 text-2xl md:text-4xl">{headingHighlight}</span>
      </h2>
      <div class="h-1.5 w-24 bg-brand-orange mx-auto rounded-full mt-8"></div>
    </div>

    <div class="max-w-4xl mx-auto grid md:grid-cols-1 gap-4">
      {faqs.map((faq) => (
        <details class="group bg-white rounded-3xl border border-gray-100 shadow-sm hover:shadow-md transition-all duration-300">
          <summary class="flex items-center justify-between p-8 cursor-pointer list-none">
            <h3 class="text-lg md:text-xl font-black text-gray-900 pr-8 group-open:text-blue-700 transition-colors">
              {faq.question}
            </h3>
            <div class="shrink-0 w-8 h-8 bg-blue-50 rounded-full flex items-center justify-center group-open:rotate-180 transition-transform duration-300">
              <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                <path d="M19 9l-7 7-7-7" />
              </svg>
            </div>
          </summary>
          <div class="px-8 pb-8">
            <div class="h-px bg-gray-100 mb-6" />
            <p class="text-gray-600 leading-relaxed text-[15px]" set:html={faq.answer} />
          </div>
        </details>
      ))}
    </div>

    <div class="mt-16 text-center">
      <p class="text-gray-500 font-medium mb-6">{supportText}</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <a
          href={whatsappUrl}
          class="flex items-center gap-3 bg-green-500 text-white px-8 py-4 rounded-full font-black hover:scale-105 transition-transform shadow-xl shadow-green-500/20"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884a9.814 9.814 0 017.001 2.894 9.81 9.81 0 012.887 6.992c-.001 5.45-4.435 9.884-9.886 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path></svg>
          {whatsappCta}
        </a>
        <a
          href={`tel:${business.phone}`}
          class="text-blue-900 font-black hover:text-brand-orange transition-colors"
        >
          {business.phone}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  details > summary::-webkit-details-marker {
    display: none;
  }
</style>
