---
import business from "../data/business.json";

interface Solution {
  title: string;
  description: string;
  icon: string;
}

interface Props {
  tagline?: string;
  title?: string;
  subtitle?: string;
  solutions?: Solution[];
}

const {
  tagline = "La Solución Definitiva",
  title = "Aísla Tu Casa Por Dentro, Sin Tocar la Fachada",
  subtitle = "Sistema Certificado · Instalación en 48h · Garantía 10 Años",
  solutions = [
    {
      title: "Eliminación Total de Humedades",
      description: "Nuestro sistema 'Beissier Therm In' crea una barrera térmica que elimina la condensación y el moho de raíz. Respira aire puro y saludable.",
      icon: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"
    },
    {
      title: "Ahorro Energético Inmediato",
      description: "Reduce hasta un 40% tu factura de gas y luz. Tu casa mantendrá el calor en invierno y el frescor en verano de forma eficiente.",
      icon: "M13 2L3 14h9l-1 8 10-12h-9l1-8z"
    },
    {
      title: "Instalación Rápida y Sin Obras",
      description: "En solo 48 horas transformamos tu hogar. Sin ruidos excesivos, sin escombros y sin necesidad de permisos comunitarios.",
      icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
    }
  ]
} = Astro.props;

const introText = "El sistema profesional Beissier Therm In aísla tu vivienda por dentro, elimina humedades y reduce tu factura energética. Perfecto para edificios protegidos de Barcelona.";
---

<section id="solucion" class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center max-w-4xl mx-auto mb-20">
      <span class="inline-block bg-[#F97316] text-white px-5 py-1.5 rounded-full text-xs font-black uppercase tracking-widest mb-6 shadow-lg shadow-orange-500/20">
        {tagline}
      </span>
      
      <h2 class="text-3xl md:text-5xl lg:text-6xl font-black text-[#1E3A8A] leading-tight mb-8">
        {title}
      </h2>
      
      <p class="text-xl md:text-2xl text-[#F97316] font-bold italic mb-10">
        {subtitle}
      </p>
      
      <p class="text-lg md:text-xl text-gray-600 font-medium leading-relaxed max-w-3xl mx-auto">
        {introText}
      </p>
      
      <div class="w-20 h-1.5 bg-[#F97316] mx-auto rounded-full mt-10"></div>
    </div>

    <!-- Solutions Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16">
      {solutions.map((item, index) => (
        <div class="group relative bg-white p-10 lg:p-12 rounded-[40px] border-2 border-gray-50 hover:border-[#1E3A8A]/20 hover:shadow-2xl hover:shadow-blue-900/10 transition-all duration-500 hover:-translate-y-3">
          <!-- Step Number -->
          <div class="absolute -top-6 left-12 w-14 h-14 bg-[#F97316] text-white rounded-2xl flex items-center justify-center font-black text-2xl shadow-xl shadow-orange-500/30 transform -rotate-6 group-hover:rotate-0 transition-transform duration-500">
            {String(index + 1).padStart(2, '0')}
          </div>

          <!-- Icon Container -->
          <div class="w-20 h-20 bg-blue-50 rounded-[30px] flex items-center justify-center mb-10 group-hover:bg-[#1E3A8A] group-hover:text-white transition-all duration-500 text-[#1E3A8A]">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d={item.icon}></path>
            </svg>
          </div>

          <!-- Content -->
          <h3 class="text-2xl lg:text-3xl font-black text-[#1F2937] mb-6 group-hover:text-[#1E3A8A] transition-colors leading-tight">
            {item.title}
          </h3>
          
          <p class="text-gray-600 text-lg leading-relaxed font-medium mb-8">
            {item.description}
          </p>

          <!-- Action Link -->
          <a href="#contacto" class="inline-flex items-center gap-3 text-[#1E3A8A] font-black uppercase tracking-widest text-sm group-hover:gap-5 transition-all">
            Solicitar info <span class="text-2xl text-[#F97316]">→</span>
          </a>
        </div>
      ))}
    </div>

    <!-- Secondary CTA -->
    <div class="mt-24 text-center">
      <div class="inline-flex flex-col md:flex-row items-center gap-6 p-4 md:p-6 bg-gray-50 rounded-[2rem] px-10 shadow-inner">
        <p class="text-gray-700 text-lg font-bold">¿Tienes dudas sobre tu caso particular?</p>
        <a href={`tel:${business.phone.replace(/\s/g, "")}`} class="flex items-center gap-3 px-8 py-4 bg-[#1E3A8A] text-white rounded-2xl font-black text-lg hover:bg-[#1E40AF] transition-all shadow-xl shadow-blue-900/30 transform hover:scale-105 active:scale-95">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 005.47 5.47l.772-1.548a1 1 0 011.06-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          LLAMAR: {business.phone}
        </a>
      </div>
    </div>
  </div>
</section>
