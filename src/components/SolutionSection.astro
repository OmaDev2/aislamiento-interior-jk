---
import business from "../data/business.json"
import home from "../data/home.json"

const { badge, heading, subtitle, intro, cards, secondaryCta } = home.solution

const icons = [
  "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5",
  "M13 2L3 14h9l-1 8 10-12h-9l1-8z",
  "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
]
---

<section id="solucion" class="py-24 lg:py-32 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-4xl mx-auto mb-20">
      <span class="inline-block px-4 py-1.5 bg-blue-100 text-blue-700 text-xs font-black uppercase tracking-widest rounded-full mb-6">
        {badge}
      </span>

      <h2 class="text-3xl md:text-5xl lg:text-6xl font-black text-brand-blue leading-tight mb-8">
        {heading}
      </h2>

      <p class="text-xl md:text-2xl text-brand-orange font-bold mb-10">
        {subtitle}
      </p>

      <p class="text-lg md:text-xl text-gray-600 font-medium leading-relaxed max-w-3xl mx-auto">
        {intro}
      </p>

      <div class="w-20 h-1.5 bg-brand-orange mx-auto rounded-full mt-10"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16">
      {cards.map((item, index) => (
        <div class="group relative bg-white p-10 lg:p-12 rounded-3xl border-2 border-gray-50 hover:border-brand-blue/20 hover:shadow-2xl hover:shadow-blue-900/10 transition-all duration-500 hover:-translate-y-3">
          <div class="absolute -top-6 left-12 w-14 h-14 bg-brand-orange text-white rounded-2xl flex items-center justify-center font-black text-2xl shadow-xl shadow-orange-500/30 transform -rotate-6 group-hover:rotate-0 transition-transform duration-500">
            {String(index + 1).padStart(2, '0')}
          </div>

          <div class="w-20 h-20 bg-blue-50 rounded-[30px] flex items-center justify-center mb-10 group-hover:bg-brand-blue group-hover:text-white transition-all duration-500 text-brand-blue">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d={icons[index]}></path>
            </svg>
          </div>

          <h3 class="text-2xl lg:text-3xl font-black text-brand-dark mb-6 group-hover:text-brand-blue transition-colors leading-tight">
            {item.title}
          </h3>

          <p class="text-gray-600 text-lg leading-relaxed font-medium mb-8">
            {item.description}
          </p>

          <a href="#contacto" class="inline-flex items-center gap-3 text-brand-blue font-black uppercase tracking-widest text-sm group-hover:gap-5 transition-all">
            Solicitar info <span class="text-2xl text-brand-orange">→</span>
          </a>
        </div>
      ))}
    </div>

    <div class="mt-24 text-center">
      <div class="inline-flex flex-col md:flex-row items-center gap-6 p-4 md:p-6 bg-gray-50 rounded-3xl px-10 shadow-inner">
        <p class="text-gray-700 text-lg font-bold">{secondaryCta}</p>
        <a href={`tel:${business.phone.replace(/\s/g, "")}`} class="flex items-center gap-3 px-8 py-4 bg-brand-blue text-white rounded-2xl font-black text-lg hover:bg-brand-blue-hover transition-all shadow-xl shadow-blue-900/30 transform hover:scale-105 active:scale-95">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 005.47 5.47l.772-1.548a1 1 0 011.06-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
          </svg>
          LLAMAR: {business.phone}
        </a>
      </div>
    </div>
  </div>
</section>
