---
import business from '../data/business.json'
---

<section id="contacto" class="py-24 lg:py-32 bg-blue-950 relative overflow-hidden text-white">
  <!-- Decorative elements -->
  <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-blue-900/50 to-transparent pointer-events-none"></div>
  <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-[#F97316]/10 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-6xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        
        <!-- Left Column: Content -->
        <div>
          <span class="inline-block px-4 py-1.5 bg-white/10 text-[#F97316] text-[10px] font-black uppercase tracking-widest rounded-full mb-8 italic">PRESUPUESTO SIN COMPROMISO</span>
          <h2 class="text-4xl md:text-6xl font-black mb-8 leading-tight">
            Solicita Tu <br />
            <span class="text-blue-400 underline decoration-[#F97316] decoration-4 underline-offset-8">Estudio Gratuito</span>
          </h2>
          <p class="text-xl text-blue-100/70 mb-12 font-medium italic leading-relaxed">
            Analizamos los puentes térmicos y problemas de condensación de tu vivienda en Barcelona sin coste alguno.
          </p>

          <div class="grid sm:grid-cols-2 gap-8 mb-12">
            <div class="bg-white/5 backdrop-blur-md rounded-[2rem] p-8 border border-white/10 hover:border-white/20 transition-all group">
              <div class="w-12 h-12 bg-[#F97316] rounded-2xl flex items-center justify-center mb-6 shadow-lg shadow-[#F97316]/20 group-hover:scale-110 transition-transform">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <p class="text-[10px] font-bold text-blue-300 uppercase tracking-widest mb-1">Llámanos</p>
              <a href={`tel:${business.phone}`} class="text-xl font-black hover:text-[#F97316] transition-colors">{business.phone}</a>
            </div>

            <div class="bg-white/5 backdrop-blur-md rounded-[2rem] p-8 border border-white/10 hover:border-white/20 transition-all group">
              <div class="w-12 h-12 bg-[#25D366] rounded-2xl flex items-center justify-center mb-6 shadow-lg shadow-green-500/20 group-hover:scale-110 transition-transform">
                <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884a9.814 9.814 0 017.001 2.894 9.81 9.81 0 012.887 6.992c-.001 5.45-4.435 9.884-9.886 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </div>
              <p class="text-[10px] font-bold text-blue-300 uppercase tracking-widest mb-1">WhatsApp</p>
              <a href="https://wa.me/34644371602" class="text-xl font-black hover:text-[#25D366] transition-colors">{business.phone}</a>
            </div>
          </div>
          
          <p class="flex items-center gap-3 text-blue-300 font-medium italic">
             <span class="w-8 h-px bg-blue-700"></span>
             Carrer d'Ausona, 71, 08033 Barcelona
          </p>
        </div>

        <!-- Right Column: Form -->
        <div class="relative">
          <div class="absolute -inset-1 bg-gradient-to-r from-[#F97316] to-blue-500 rounded-[3rem] blur opacity-25"></div>
          <form
            name="contacto"
            method="POST"
            action="/gracias/"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="relative bg-blue-900 border border-white/10 rounded-[3rem] p-10 lg:p-14 space-y-6"
          >
            <input type="hidden" name="form-name" value="contacto" />
            
            <div class="grid md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label for="nombre" class="text-xs font-black uppercase tracking-widest text-blue-300 ml-4">Nombre Completo</label>
                <input type="text" id="nombre" name="nombre" required
                  class="w-full px-6 py-5 rounded-full bg-blue-950 border border-white/10 text-white placeholder-blue-700/50 focus:outline-none focus:border-[#F97316] transition-all"
                  placeholder="Ej: Juan Pérez" />
              </div>
              <div class="space-y-2">
                <label for="telefono" class="text-xs font-black uppercase tracking-widest text-blue-300 ml-4">Teléfono Móvil</label>
                <input type="tel" id="telefono" name="telefono" required
                  class="w-full px-6 py-5 rounded-full bg-blue-950 border border-white/10 text-white placeholder-blue-700/50 focus:outline-none focus:border-[#F97316] transition-all"
                  placeholder="600 000 000" />
              </div>
            </div>

            <div class="space-y-2">
              <label for="mensaje" class="text-xs font-black uppercase tracking-widest text-blue-300 ml-4">Tu Consulta (¿Qué necesitas aislar?)</label>
              <textarea id="mensaje" name="mensaje" rows="4"
                class="w-full px-8 py-6 rounded-[2rem] bg-blue-950 border border-white/10 text-white placeholder-blue-700/50 focus:outline-none focus:border-[#F97316] transition-all resize-none"
                placeholder="Describe brevemente tu problema de humedad o frío..."></textarea>
            </div>

            <button type="submit"
              class="w-full py-6 bg-[#F97316] hover:bg-white hover:text-blue-900 text-white font-black text-xl rounded-full transition-all shadow-2xl shadow-black/20 transform hover:scale-[1.02] active:scale-[0.98]">
              RECIBIR MI ESTUDIO GRATIS
            </button>
            
            <p class="text-center text-[10px] text-blue-400/50 uppercase tracking-widest font-bold">
              Respetamos tu privacidad. Recibirás tu presupuesto en menos de 24h.
            </p>
          </form>
        </div>

      </div>
    </div>
  </div>
</section>
