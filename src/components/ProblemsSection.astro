---
---

<section id="problemas" class="py-20 lg:py-32 bg-gray-50 border-y border-gray-100 overflow-hidden relative">
  <!-- Subtle decorative elements -->
  <div class="absolute top-0 right-0 w-64 h-64 bg-blue-100/30 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 bg-orange-100/30 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>

  <div class="container mx-auto px-4 relative z-10">
    <!-- Header -->
    <div class="max-w-3xl mx-auto text-center mb-16 lg:mb-24">
      <span class="inline-block px-4 py-1.5 bg-blue-100 text-blue-700 text-xs font-bold uppercase tracking-widest rounded-full mb-6">Realidad en Barcelona</span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-gray-900 leading-tight mb-8">
        ¿Te Suena Alguno de Estos Problemas en tu Vivienda?
      </h2>
      <div class="h-1.5 w-24 bg-[#F97316] mx-auto rounded-full"></div>
    </div>

    <!-- Problems Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {[
        { 
          title: "Paredes Heladas en Invierno", 
          desc: "Tocas la pared y está congelada. Tu calefacción trabaja el doble sin conseguir confort en tu piso de Barcelona.",
          icon: "M2 12h10M9 4v16m-6-11 3 3-3 3M12 6 9 9 6 6m0 12 3-3 1.5 1.5M20 4v10.54a4 4 0 1 1-4 0V4a2 2 0 0 1 4 0Z"
        },
        { 
          title: "Moho y Manchas Negras", 
          desc: "Aparecen en esquinas y detrás de muebles. Afecta a tu salud y la de tu familia. Problema común en edificios antiguos.",
          icon: "M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"
        },
        { 
          title: "Facturas Desorbitadas", 
          desc: "Pagas una fortuna en calefacción pero el calor se escapa por las paredes mal aisladas.",
          icon: "M23 6l-9.5 9.5-5-5L1 18M17 6h6v6"
        },
        { 
          title: "No Puedes Hacer SATE Exterior", 
          desc: "Edificio protegido o la comunidad no aprueba obras en fachada. Situación muy común en el Eixample y Ciutat Vella.",
          icon: "M4 2h16v20H4V2Zm5 20v-4h6v4M8 6h.01M16 6h.01M12 6h.01M12 10h.01M12 14h.01M16 10h.01M16 14h.01M8 10h.01M8 14h.01"
        }
      ].map((item, i) => (
        <div class="bg-white rounded-[2rem] p-8 border-2 border-transparent shadow-lg hover:shadow-2xl hover:border-[#F97316] hover:-translate-y-2 transition-all duration-300 group">
          <div class="w-14 h-14 bg-gray-50 rounded-2xl flex items-center justify-center mb-6 text-[#1E3A8A] group-hover:bg-[#1E3A8A] group-hover:text-white transition-all duration-300">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d={item.icon}></path>
            </svg>
          </div>
          <h3 class="text-xl font-extrabold text-gray-900 mb-4 leading-tight group-hover:text-[#1E3A8A] transition-colors">
            {item.title}
          </h3>
          <p class="text-gray-500 leading-relaxed text-sm lg:text-base">
            {item.desc}
          </p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-16 text-center">
      <a href="#contacto" class="inline-flex items-center gap-3 bg-[#F97316] hover:bg-[#EA580C] text-white px-8 py-5 rounded-full font-bold text-lg shadow-xl shadow-[#F97316]/30 transition-all transform hover:scale-105 active:scale-95">
        Quiero Quitar la Humedad de Mi Casa
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </a>
    </div>
  </div>
</section>
