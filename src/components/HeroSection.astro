---
import { Image } from "astro:assets";
import heroImg from "../assets/images/hero-bg.png";
import business from "../data/business.json";
import home from "../data/home.json";

interface Props {
  h1: string;
  subtitle?: string;
}

const {
  h1 = home.h1 || "¿Paredes Frías o Humedad en Casa?",
  subtitle = home.heroSubtitle ||
    "Elimina el frío, el moho y la condensación en 48h sin reformar tu vivienda.",
} = Astro.props;

const phone = business.phone || "93 694 76 63";
const phoneLink = `tel:${phone.replace(/\s/g, "")}`;
---

<section
  class="hero-section relative py-20 lg:py-32 overflow-hidden bg-[#1E3A8A]"
>
  <!-- Astro Image Background -->
  <div class="absolute inset-0 z-0">
    <Image
      src={heroImg}
      alt="Aislamiento térmico interior de alta calidad en Barcelona"
      class="w-full h-full object-cover opacity-45"
      loading="eager"
    />
    <!-- Overlay for readability -->
    <div
      class="absolute inset-0 bg-[#1E3A8A]/85 mix-blend-multiply transition-opacity duration-300"
    >
    </div>
    <div
      class="absolute inset-0 bg-gradient-to-tr from-[#1E3A8A] via-transparent to-[#1E3A8A]/20 opacity-90"
    >
    </div>
  </div>

  <!-- Content Container -->
  <div class="container mx-auto px-4 relative z-10">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
      <!-- LEFT CONTENT: Text and Info -->
      <div class="w-full lg:w-3/5 text-white">
        <!-- Trust Badge -->
        <div
          class="trust-badge flex items-center gap-2 bg-white/10 backdrop-blur-md border border-white/20 rounded-full px-4 py-1.5 mb-8 w-fit animate-fade-in-down"
        >
          <svg width="20" height="20" fill="#FFB800" viewBox="0 0 24 24">
            <path
              d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"
            ></path>
          </svg>
          <span class="text-xs md:text-sm font-medium tracking-tight">
            4.9/5 - 87 Valoraciones +80 viviendas en Barcelona
          </span>
        </div>

        <!-- H1 Heading -->
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-6 animate-fade-in text-white"
        >
          {h1}
          <br />
          <span class="text-[#F97316] block mt-1 drop-shadow-sm"
            >Solución Sin Obras en Barcelona</span
          >
        </h1>

        <!-- Subtitle -->
        <p
          class="text-lg md:text-xl text-white/90 mb-10 leading-relaxed max-w-2xl animate-fade-in-up"
        >
          {subtitle}
          <br class="hidden md:block" />
          Ahorra hasta un 40% en calefacción desde el primer invierno.
        </p>

        <!-- Pain Points Grid (Features) -->
        <div
          class="grid grid-cols-2 gap-4 mb-10 animate-fade-in-up delay-200"
        >
          {
            [
              {
                icon: "M2 12h10M9 4v16m-6-11 3 3-3 3M12 6 9 9 6 6m0 12 3-3 1.5 1.5",
                text: "Paredes Frías",
              },
              {
                icon: "M8 2c3 0 5 2 8 2s4-1 4-1v11s-1 1-4 1-5-2-8-2-4 1-4 1V2s1-1 4-1M4 22v-7",
                text: "Moho y Humedad",
              },
              {
                icon: "M12 1v22M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6",
                text: "Facturas Altas",
              },
              {
                icon: "M4 2h16v20H4V2Zm5 20v-4h6v4",
                text: "Sin Obra Exterior",
              },
            ].map((item) => (
              <div class="flex items-center gap-3 bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl p-4 hover:bg-white/10 transition-all group">
                <div class="w-10 h-10 bg-[#F97316]/20 rounded-xl flex items-center justify-center text-[#F97316] group-hover:scale-110 transition-transform">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d={item.icon} />
                  </svg>
                </div>
                <span class="text-sm font-bold tracking-tight">{item.text}</span>
              </div>
            ))
          }
        </div>

        <!-- Trust Features -->
        <div class="flex flex-wrap gap-x-6 gap-y-3 mb-12 animate-fade-in-up delay-300">
          {
            ["Sin tocar fachada", "Garantía 10 años", "Ahorro 40%"].map((f) => (
              <div class="flex items-center gap-2 text-sm font-medium text-blue-100/80">
                <svg class="w-5 h-5 text-[#F97316]" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {f}
              </div>
            ))
          }
        </div>

        <!-- Hero Buttons -->
        <div
          class="flex flex-col sm:flex-row gap-4 items-center animate-fade-in-up delay-400"
        >
          <a
            href="#contacto"
            class="w-full sm:w-auto px-10 py-5 bg-[#F97316] hover:bg-[#EA580C] text-white font-black text-lg rounded-full shadow-2xl shadow-[#F97316]/30 transition-all text-center uppercase tracking-tight transform hover:scale-105"
          >
            Presupuesto Gratis
          </a>
          <a
            href={phoneLink}
            class="w-full sm:w-auto px-10 py-5 bg-white/10 hover:bg-white/20 text-white border-2 border-white/20 font-black text-lg rounded-full shadow-lg transition-all text-center flex items-center justify-center gap-3 uppercase tracking-tight transform hover:scale-105"
          >
            Llamar {phone}
          </a>
        </div>
      </div>

      <!-- RIGHT FORM -->
      <div class="w-full lg:w-2/5 animate-fade-in-right">
        <div
          class="form-card bg-white rounded-3xl shadow-2xl p-8 md:p-10 text-gray-800"
        >
          <h2 class="text-3xl font-extrabold text-[#1E3A8A] mb-2">
            ¿Cuánto Me Cuesta?
          </h2>
          <p class="text-sm text-gray-500 mb-8 leading-relaxed font-medium">
            Te calculamos el precio en 24h · Inspección gratis a domicilio
          </p>

          <form
            id="hero-contact-form"
            name="hero-form"
            method="POST"
            action="/gracias/"
            data-netlify="true"
            class="space-y-4"
          >
            <input type="hidden" name="form-name" value="hero-form" />

            <div class="relative">
              <input
                type="text"
                name="nombre"
                placeholder="Tu nombre"
                class="w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-2xl focus:ring-2 focus:ring-[#1E3A8A] focus:border-transparent outline-none transition-all"
                required
              />
            </div>

            <div class="relative">
              <input
                type="tel"
                name="telefono"
                placeholder="Teléfono"
                class="w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-2xl focus:ring-2 focus:ring-[#1E3A8A] focus:border-transparent outline-none transition-all"
                required
              />
            </div>

            <div class="relative">
              <input
                type="text"
                name="codigoPostal"
                placeholder="Código Postal (Barcelona)"
                class="w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-2xl focus:ring-2 focus:ring-[#1E3A8A] focus:border-transparent outline-none transition-all"
                required
              />
            </div>

            <div class="relative">
              <select
                name="problema"
                class="w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-2xl focus:ring-2 focus:ring-[#1E3A8A] focus:border-transparent outline-none transition-all appearance-none text-gray-400 focus:text-gray-900"
                required
              >
                <option value="">¿Cuál es tu problema?</option>
                <option value="frio">Paredes frías / Pérdida de calor</option>
                <option value="moho">Moho y humedad</option>
                <option value="factura">Factura calefacción alta</option>
                <option value="sate">No puedo hacer SATE exterior</option>
              </select>
              <div
                class="absolute right-5 top-1/2 -translate-y-1/2 pointer-events-none text-gray-400"
              >
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg
                >
              </div>
            </div>

            <button
              type="submit"
              class="w-full py-5 bg-[#F97316] hover:bg-[#EA580C] text-white font-black text-xl rounded-2xl shadow-xl shadow-[#F97316]/30 transition-all transform hover:scale-[1.02] active:scale-[0.98] mt-4 uppercase tracking-tight"
            >
              Ver Cuánto Me Cuesta →
            </button>

            <div
              class="flex items-center justify-center gap-2 pt-4 text-xs font-semibold text-gray-400"
            >
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><rect x="3" y="11" width="18" height="11" rx="2" ry="2"
                ></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg
              >
              <span>Sin compromiso · Respuesta en 24h · Sin spam</span>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Decorative Gradient Blobs -->
  <div
    class="absolute -top-24 -left-24 w-96 h-96 bg-[#1D4ED8] rounded-full blur-[160px] opacity-20 pointer-events-none"
  >
  </div>
  <div
    class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-[#1E3A8A] rounded-full blur-[200px] opacity-30 pointer-events-none"
  >
  </div>
</section>

<style>
  .hero-section {
    min-height: 85vh;
    display: flex;
    align-items: center;
  }

  /* Animations */
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeInDown {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeInRight {
    from { opacity: 0; transform: translateX(30px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .animate-fade-in {
    animation: fadeIn 1s ease-out forwards;
  }
  .animate-fade-in-up {
    opacity: 0;
    animation: fadeInUp 0.8s ease-out forwards;
  }
  .animate-fade-in-down {
    animation: fadeInDown 0.8s ease-out forwards;
  }
  .animate-fade-in-right {
    opacity: 0;
    animation: fadeInRight 1s ease-out forwards;
  }

  .delay-200 { animation-delay: 0.2s; }
  .delay-300 { animation-delay: 0.3s; }
  .delay-400 { animation-delay: 0.4s; }
</style>
