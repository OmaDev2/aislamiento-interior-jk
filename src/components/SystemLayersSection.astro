---
import home from '../data/home.json'

const { badge, heading, headingHighlight, warning, layers, specsTitle, specsSubtitle, specs } = home.systemLayers
---

<section id="sistema" class="py-24 lg:py-32 bg-white overflow-hidden relative">
  <div class="absolute inset-0 bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] [background-size:20px_20px] opacity-30"></div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-4xl mx-auto text-center mb-16 lg:mb-24">
      <span class="inline-block px-4 py-1.5 bg-blue-100 text-blue-700 text-xs font-black uppercase tracking-widest rounded-full mb-6">{badge}</span>
      <h2 class="text-3xl md:text-5xl font-black text-gray-900 leading-tight mb-8">
        {heading} <br class="hidden md:block" />
        <span class="text-blue-700">{headingHighlight}</span>
      </h2>
      <div class="h-1.5 w-24 bg-brand-orange mx-auto rounded-full mb-12"></div>

      <div class="max-w-2xl mx-auto bg-amber-50 border-l-4 border-amber-400 p-6 rounded-r-2xl shadow-sm text-left flex gap-4">
        <div class="shrink-0">
          <svg class="w-6 h-6 text-amber-500" fill="currentColor" viewBox="0 0 24 24">
            <path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/>
          </svg>
        </div>
        <p class="text-amber-900 text-sm md:text-base leading-relaxed" set:html={warning} />
      </div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8 mb-20">
      {layers.map((capa, i) => (
        <div class={`group relative p-8 rounded-3xl border-2 transition-all duration-500 hover:shadow-2xl hover:border-brand-blue hover:-translate-y-2 ${capa.featured ? 'bg-blue-900 text-white border-blue-900 scale-105 z-10 shadow-xl' : 'bg-white text-gray-900 border-transparent shadow-lg shadow-blue-900/5'}`}>
          <div class={`inline-block px-4 py-1 rounded-full text-[10px] font-black uppercase tracking-widest mb-6 ${capa.featured ? 'bg-brand-orange text-white shadow-lg shadow-orange-500/20' : 'bg-blue-100 text-blue-700'}`}>
            Capa {i + 1}
          </div>

          <h3 class="text-xl font-black mb-4 leading-tight">{capa.title}</h3>
          {capa.subtitle && <p class="text-xs font-bold uppercase tracking-wide mb-4 opacity-75">{capa.subtitle}</p>}
          {capa.badge && (
            <div class="flex items-center gap-2 mb-6 bg-green-50 text-green-700 text-[10px] font-bold px-3 py-1.5 rounded-full border border-green-100 w-fit">
              <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              {capa.badge}
            </div>
          )}

          <ul class="space-y-3">
            {capa.items.map((item) => (
              <li class="flex items-start gap-2.5 text-sm">
                <svg class={`w-4 h-4 mt-0.5 shrink-0 ${capa.featured ? 'text-brand-orange' : 'text-blue-500'}`} fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                  <path d="M5 13l4 4L19 7"></path>
                </svg>
                <span class={capa.featured ? 'text-white/90' : 'text-gray-500'}>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="max-w-4xl mx-auto bg-white rounded-3xl p-10 lg:p-14 border border-blue-100 shadow-xl shadow-blue-900/5 items-center justify-between flex flex-col md:flex-row gap-12 text-center md:text-left">
      <div class="md:w-1/3">
        <h4 class="text-2xl font-black text-blue-950 mb-2">{specsTitle}</h4>
        <p class="text-gray-500 text-sm font-medium uppercase tracking-widest">{specsSubtitle}</p>
      </div>

      <div class="md:w-2/3 grid grid-cols-2 gap-8 w-full">
        {specs.map((spec) => (
          <div class="flex items-center gap-4">
            <span class="text-2xl">{spec.icon}</span>
            <div>
              <p class="text-[10px] font-bold text-gray-400 uppercase tracking-tighter">{spec.label}</p>
              <p class="text-lg font-black text-blue-900">{spec.value}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
