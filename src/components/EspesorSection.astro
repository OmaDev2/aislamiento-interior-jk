---
---

<section id="espesor" class="py-24 lg:py-32 bg-white relative overflow-hidden">
  <div class="container mx-auto px-4">
    <div class="flex flex-col lg:flex-row items-center gap-16 lg:gap-24">
      
      <!-- Text Side -->
      <div class="lg:w-1/2">
        <span class="inline-block px-4 py-1 bg-[#F97316] text-white text-[10px] font-bold uppercase tracking-widest rounded-full mb-6">
          FACTOR ESPESOR
        </span>
        <h2 class="text-4xl lg:text-5xl font-black text-gray-900 leading-tight mb-8">
          Solo 15mm.<br />
          <span class="text-[#F97316]">Tu Piso No Pierde Ni 1 Metro</span>
        </h2>
        <p class="text-lg text-gray-600 leading-relaxed mb-8">
          En pisos pequeños de Barcelona, cada centímetro cuenta. El sistema <strong>Beissier Therm In</strong> utiliza placas de poliestireno de alta densidad de bajo espesor que ofrecen máximo aislamiento con mínima pérdida de espacio.
        </p>
        
        <!-- Info Badge -->
        <div class="bg-blue-50 border border-blue-100 p-4 rounded-2xl flex items-center gap-4 mb-10">
          <div class="w-10 h-10 bg-[#10B981]/10 rounded-full flex items-center justify-center shrink-0">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
          </div>
          <span class="text-sm font-bold text-blue-900">Ideal para pisos de 40-70m² en Eixample, Gràcia y Ciutat Vella</span>
        </div>

        <a href="#contacto" class="inline-flex items-center gap-3 bg-[#F97316] hover:bg-[#EA580C] text-white px-8 py-5 rounded-full font-bold text-lg shadow-xl shadow-[#F97316]/30 transition-all transform hover:translate-x-2 active:scale-95">
          Ver Precio Para Mi Piso
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
      </div>

      <!-- Comparison Side -->
      <div class="lg:w-1/2 w-full">
        <div class="bg-white rounded-[2rem] p-8 md:p-12 shadow-2xl shadow-blue-900/5 border border-gray-100">
          <h3 class="text-xl font-black text-center text-gray-900 mb-12 uppercase tracking-wide">Comparativa de Espesores</h3>
          
          <div class="space-y-10">
            <!-- Beissier -->
            <div class="space-y-4">
              <div class="flex items-center justify-between">
                <span class="font-bold text-blue-900">Beissier Therm In</span>
                <span class="bg-[#10B981] text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest">Recomendado</span>
              </div>
              <div class="relative h-6 bg-gray-100 rounded-full overflow-hidden">
                <div class="absolute top-0 left-0 h-full w-[19%] bg-[#10B981] rounded-full transition-all duration-1000"></div>
                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-xs font-bold text-gray-400">15mm</span>
              </div>
            </div>

            <!-- Alternative 1 -->
            <div class="space-y-4">
              <div class="flex items-center justify-between">
                <span class="font-bold text-gray-600">Pladur + Lana mineral</span>
              </div>
              <div class="relative h-6 bg-gray-100 rounded-full overflow-hidden">
                <div class="absolute top-0 left-0 h-full w-[75%] bg-red-400 rounded-full transition-all duration-1000 delay-200"></div>
                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-xs font-bold text-gray-400 font-mono">60-80mm</span>
              </div>
            </div>

            <!-- Alternative 2 -->
            <div class="space-y-4">
              <div class="flex items-center justify-between">
                <span class="font-bold text-gray-600">Trasdosado aislante</span>
              </div>
              <div class="relative h-6 bg-gray-100 rounded-full overflow-hidden">
                <div class="absolute top-0 left-0 h-full w-full bg-red-400 rounded-full transition-all duration-1000 delay-400"></div>
                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-xs font-bold text-gray-400 font-mono text-center">80-120mm</span>
              </div>
            </div>

            <!-- Problem SATE -->
            <div class="space-y-4">
              <div class="flex items-center justify-between opacity-50">
                <span class="font-bold text-gray-400 line-through">SATE Exterior</span>
                <span class="bg-red-500 text-white text-[9px] font-bold px-2 py-0.5 rounded-full uppercase tracking-tighter">No viable en fachada protegida</span>
              </div>
              <div class="h-6 bg-gray-50 border-2 border-dashed border-gray-200 rounded-full flex items-center justify-center">
                <span class="text-[10px] font-bold text-gray-300">N/A</span>
              </div>
            </div>
          </div>

          <p class="mt-12 text-sm text-center text-gray-500 font-medium">
            Con Beissier Therm In pierdes <strong class="text-blue-900 font-black italic">4-8 veces menos espacio</strong> que con otros sistemas de aislamiento interior.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>
