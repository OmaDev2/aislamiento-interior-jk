---
import home from '../data/home.json'

const { badge, heading, headingHighlight, text, infoBadge, cta, comparisonTitle, comparisons, comparisonFooter } = home.espesor
---

<section id="espesor" class="py-24 lg:py-32 bg-gray-50 relative overflow-hidden">
  <div class="container mx-auto px-4">
    <div class="flex flex-col lg:flex-row items-center gap-16 lg:gap-24">

      <div class="lg:w-1/2">
        <span class="inline-block px-4 py-1.5 bg-blue-100 text-blue-700 text-xs font-black uppercase tracking-widest rounded-full mb-6">
          {badge}
        </span>
        <h2 class="text-4xl lg:text-5xl font-black text-gray-900 leading-tight mb-8">
          {heading}<br />
          <span class="text-brand-orange">{headingHighlight}</span>
        </h2>
        <p class="text-lg text-gray-600 leading-relaxed mb-8" set:html={text} />

        <div class="bg-blue-50 border border-blue-100 p-4 rounded-2xl flex items-center gap-4 mb-10">
          <div class="w-10 h-10 bg-emerald-500/10 rounded-full flex items-center justify-center shrink-0">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
          </div>
          <span class="text-sm font-bold text-blue-900">{infoBadge}</span>
        </div>

        <a href="#contacto" class="inline-flex items-center gap-3 bg-brand-orange hover:bg-brand-orange-hover text-white px-8 py-5 rounded-full font-bold text-lg shadow-xl shadow-brand-orange/30 transition-all transform hover:translate-x-2 active:scale-95">
          {cta}
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
      </div>

      <div class="lg:w-1/2 w-full">
        <div class="bg-white rounded-3xl p-8 md:p-12 shadow-2xl shadow-blue-900/5 border border-gray-100">
          <h3 class="text-xl font-black text-center text-gray-900 mb-12 uppercase tracking-wide">{comparisonTitle}</h3>

          <div class="space-y-10">
            {comparisons.map((c) => (
              <div class="space-y-4">
                <div class={`flex items-center justify-between ${c.notViable ? 'opacity-50' : ''}`}>
                  <span class={`font-bold ${c.recommended ? 'text-blue-900' : c.notViable ? 'text-gray-400 line-through' : 'text-gray-600'}`}>{c.name}</span>
                  {c.recommended && <span class="bg-emerald-500 text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest">Recomendado</span>}
                  {c.notViable && <span class="bg-red-500 text-white text-[9px] font-bold px-2 py-0.5 rounded-full uppercase tracking-tighter">{c.notViableReason}</span>}
                </div>
                {c.notViable ? (
                  <div class="h-6 bg-gray-50 border-2 border-dashed border-gray-200 rounded-full flex items-center justify-center">
                    <span class="text-[10px] font-bold text-gray-300">{c.thickness}</span>
                  </div>
                ) : (
                  <div class="relative h-6 bg-gray-100 rounded-full overflow-hidden">
                    <div class={`absolute top-0 left-0 h-full rounded-full transition-all duration-1000 ${c.recommended ? 'w-[19%] bg-emerald-500' : `bg-red-400`}`} style={c.widthPercent ? `width:${c.widthPercent}%` : ''}></div>
                    <span class="absolute right-4 top-1/2 -translate-y-1/2 text-xs font-bold text-gray-400">{c.thickness}</span>
                  </div>
                )}
              </div>
            ))}
          </div>

          <p class="mt-12 text-sm text-center text-gray-500 font-medium" set:html={comparisonFooter} />
        </div>
      </div>

    </div>
  </div>
</section>
