---
import business from '../data/business.json'
import home from '../data/home.json'

const { badge, heading, headingHighlight, subtitle, signals } = home.cityGrid
---

<section id="zonas" class="py-24 lg:py-32 bg-gray-50 relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(#3b82f6_1px,transparent_1px)] [background-size:40px_40px] opacity-[0.03]"></div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-4xl mx-auto text-center mb-16">
      <span class="inline-block px-4 py-1.5 bg-blue-100 text-blue-700 text-xs font-black uppercase tracking-widest rounded-full mb-6">{badge}</span>
      <h2 class="text-3xl md:text-5xl font-black text-gray-900 leading-tight mb-6">
        {heading} <span class="text-blue-700">{headingHighlight}</span>
      </h2>
      <p class="text-lg text-gray-500 font-medium max-w-2xl mx-auto">
        {subtitle}
      </p>
      <div class="h-1 w-20 bg-brand-orange mx-auto rounded-full mt-8"></div>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-5 gap-3">
      {business.serviceArea.map((city: string) => {
        const slug = city.toLowerCase()
          .normalize("NFD")
          .replace(/[\u0300-\u036f]/g, "")
          .replace(/\s+/g, '-')
          .replace(/'/g, '');
        const href = city === "Barcelona" ? '/' : `/${slug}/`
        return (
          <a
            href={href}
            class="group flex flex-col items-center justify-center gap-3 bg-white hover:bg-blue-900 border border-gray-100 hover:border-blue-900 rounded-3xl p-6 transition-all duration-300 shadow-sm hover:shadow-xl hover:-translate-y-1"
          >
            <div class="w-10 h-10 rounded-2xl bg-gray-50 group-hover:bg-white/10 flex items-center justify-center shadow-inner transition-colors">
               <svg class="w-5 h-5 text-blue-700 group-hover:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                 <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                 <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
               </svg>
            </div>
            <span class="text-xs font-black uppercase tracking-widest text-brand-orange group-hover:text-white transition-colors">{city}</span>
          </a>
        )
      })}
    </div>

    <div class="mt-16 text-center">
      <div class="inline-flex flex-wrap items-center justify-center gap-x-8 gap-y-4 px-10 py-6 bg-blue-50 rounded-full border border-blue-100 font-medium text-blue-900">
         {signals.map((s) => (
           <span class="flex items-center gap-2"><div class="w-2 h-2 bg-green-500 rounded-full"></div> {s}</span>
         ))}
      </div>
    </div>
  </div>
</section>
