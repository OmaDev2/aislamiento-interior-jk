---
import BaseLayout from '../layouts/BaseLayout.astro'
import HeroSection from '../components/HeroSection.astro'
import UrgencyStrip from '../components/UrgencyStrip.astro'
import ProblemsSection from '../components/ProblemsSection.astro'
import SolutionSection from '../components/SolutionSection.astro'
import EspesorSection from '../components/EspesorSection.astro'
import SystemLayersSection from '../components/SystemLayersSection.astro'
import WhenNeededSection from '../components/WhenNeededSection.astro'
import ProcessSection from '../components/ProcessSection.astro'
import RealCasesSection from '../components/RealCasesSection.astro'
import FaqSection from '../components/FaqSection.astro'
import CityGrid from '../components/CityGrid.astro'
import ContactSection from '../components/ContactSection.astro'
import business from '../data/business.json'
import home from '../data/home.json'

const h1 = home.h1 || `${business.name} en ${business.serviceArea?.[0]}`
const heroSubtitle = home.heroSubtitle || undefined
---

<BaseLayout
  title={(home as any).siteTitle || `${business.name} en ${business.serviceArea?.[0]} | Presupuesto gratis`}
  description={(home as any).metaDescription || business.description.slice(0, 155)}
>

  <UrgencyStrip />
  <HeroSection h1={h1} subtitle={heroSubtitle} />

  <ProblemsSection />
  <SolutionSection />
  <EspesorSection />
  <SystemLayersSection />
  <WhenNeededSection />
  <ProcessSection />
  <RealCasesSection />
  <FaqSection />

  <CityGrid />

  <ContactSection />

</BaseLayout>
